# ======================================
# Bitcoin Experimental Engine (.env)
# ======================================

# --- Backend ---
FLASK_ENV=development
SECRET_KEY=change-me
DATABASE_URL=postgresql+psycopg://bee_user:bee_password@localhost:5432/bee
REDIS_URL=redis://localhost:6379/0
SESSION_BACKEND=redis
SESSION_TIMEOUT_MINUTES=120
BINANCE_BASE_URL=https://api.binance.com
BACKEND_API_ORIGIN=http://localhost:5000

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/backend

# --- Optional QA Role Account Placeholders (non-secret) ---
# Use these as identity labels for manual role-based UI checks.
# Do NOT commit real credentials. Replace with local seeded values.
QA_USER_ACCOUNT=user@bee.local
QA_MODERATOR_ACCOUNT=moderator@bee.local
QA_ADMIN_ACCOUNT=admin@bee.local
QA_USER_PASSWORD=User@12345
QA_MODERATOR_PASSWORD=Moderator@12345
QA_ADMIN_PASSWORD=Admin@12345
